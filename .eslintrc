{
	"extends": ["@nuxtjs/eslint-config-typescript"],
	"rules": {
		"no-tabs": "off",
		"semi": ["error", "always"],
		"vue/html-indent": "off",
		"comma-dangle": "off",
		"indent": ["error", "tab"],
		"vue/singleline-html-element-content-newline": "off",
		"vue/multi-word-component-names": "off"
	}
}
